generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  /** Pooled URL (e.g. Neon `*-pooler.*`) — fine for the running app. */
  url       = env("DATABASE_URL")
  /** Direct / non-pooler URL — required for `migrate deploy` (advisory locks). From Neon: same branch, “direct” connection. */
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum Role {
  USER
  ADMIN
  /** Full admin plus user management (/admin/users). Multiple users may have this role. */
  SUPER_ADMIN
}

model User {
  id              String    @id @default(cuid())
  name            String?
  email           String?   @unique
  emailVerified   DateTime?
  image           String?
  passwordHash    String?
  phone           String?
  residence       String?
  gender          String?
  role            Role      @default(USER)
  lastLoginAt     DateTime?
  accounts        Account[]
  sessions        Session[]

  @@index([lastLoginAt])
  @@index([role])
}

/// Short-lived email verification codes for registration (not NextAuth VerificationToken).
model SignupOtp {
  id        String   @id @default(cuid())
  email     String
  codeHash  String
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([email])
}

/// Profile + password pending email verification (created on register submit, consumed after OTP).
model RegistrationDraft {
  id           String   @id @default(cuid())
  email        String   @unique
  fullName     String
  phone        String
  residence    String
  gender       String
  passwordHash String
  createdAt    DateTime @default(now())
  expiresAt    DateTime

  @@index([expiresAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Tender {
  id                   String   @id @default(cuid())
  title                String
  organization         String
  category             String
  location             String
  postedDate           DateTime
  expiryDate           DateTime
  description          String   @db.Text
  /** Rich-text tender overview (TipTap HTML); `description` holds plain text for search/snippets. */
  descriptionHtml      String   @default("") @db.Text
  organizationBlurb    String   @default("") @db.Text
  /** Optional logo (Blob URL or /api/blob/...) shown on listings and detail. */
  organizationLogoUrl  String?
  documents            Json     @default("[]")
  detailRows           Json     @default("[]")
  /** Legacy row-based requirements; prefer `requirementsHtml` for new content. */
  requirements         Json     @default("[]")
  /** Rich-text scope / eligibility (TipTap HTML). */
  requirementsHtml     String   @default("") @db.Text
  /** Application steps (TipTap HTML), shown as "How to apply". */
  howToApply           String   @default("") @db.Text
  contact              Json     @default("{}")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([category])
  @@index([postedDate])
}

model MarketplaceListing {
  id          String   @id @default(cuid())
  title       String
  price       String
  category    String
  imageUrl    String
  description String   @db.Text
  seller      String
  highlights  Json     @default("[]")
  contact     Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
}

model Blog {
  id        String   @id @default(cuid())
  title     String
  content   String   @db.Text
  imageUrl  String?
  author    String
  category  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
}
